  "pair": [
    {
      "id": "list_devices",
      "template": "list_devices",
      "options": {
        "singular": true
      },
      "navigation": {
        "next": "device_settings"
      }
    },
    {
      "id": "device_settings"
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ]
