{
  "name": {
    "en": "HRV Wi-Fi"
  },
  "class": "fan",
  "capabilities": [
    "onoff",
    "breezy_speed_mode",
    "breezy_operation_mode",
    "breezy_timer_mode",
    "manualSpeed",
    "fan_speed",
    "alarm_boost",
    "alarm_filter",
    "alarm_generic",
    "filter_timer",
    "button_reset_filter",
    "measure_humidity",
    "measure_RPM",
    "timerMode_timer",
    "alarm_connectivity"
  ],
  "energy": {
    "approximation": {
      "usageOn": 20,
      "usageOff": 0.5
    }
  },
  "platforms": [
    "local"
  ],
  "connectivity": [
    "lan"
  ],
  "images": {
    "small": "{{driverAssetsPath}}/images/small.png",
    "large": "{{driverAssetsPath}}/images/large.png",
    "xlarge": "{{driverAssetsPath}}/images/xlarge.png"
